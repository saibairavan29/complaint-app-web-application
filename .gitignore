# ============================================================
# NEXT.JS FRONTEND
# ============================================================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
/.next/
/out/
/build

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# ============================================================
# ENVIRONMENT FILES (secrets / API keys)
# ============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.*
!.env.example         # keep the example template committed

# ============================================================
# DJANGO BACKEND
# ============================================================

# Python compiled files
*.py[cod]
__pycache__/
*.so
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
backend/db.sqlite3
backend/backups/
backend/media/
backend/logs/
backend/static_collected/
backend/staticfiles/

# ============================================================
# MISCELLANEOUS
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editors / IDE
.idea/
.vscode/
*.swp
*.swo
*.bak
*~

# Test artefacts / coverage
/coverage
.coverage
htmlcov/

# Temp / misc files generated during development
findstr
temp_projects.js

# PEM / certificates
*.pem
